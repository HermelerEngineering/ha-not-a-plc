{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HermelerEngineering/ha-not-a-plc/schema/program.schema.json",
  "title": "Not-a-PLC ladder program",
  "type": "object",
  "required": ["tags", "networks"],
  "additionalProperties": false,
  "properties": {
    "meta": { "type": "object" },
    "scan_interval_ms": { "type": "integer", "exclusiveMinimum": 0 },
    "tags": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/tag" }
    },
    "fbs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/fb" }
    },
    "networks": {
      "type": "array",
      "items": { "$ref": "#/$defs/network" }
    }
  },
  "$defs": {
    "tag": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["input", "coil", "memory", "temp"] },
        "type": { "enum": ["BOOL", "REAL", "TIME"] },
        "source": { "type": "string" },
        "retain": { "type": "boolean" },
        "on_unavailable": { "enum": ["false", "hold"] },
        "true_states": { "type": "array", "items": { "type": "string" } },
        "writes": {
          "type": "object",
          "required": ["target"],
          "additionalProperties": false,
          "properties": {
            "target": { "type": "string" },
            "service": { "type": "string" },
            "value_key": { "type": "string" }
          }
        }
      }
    },
    "network": {
      "type": "object",
      "required": ["id", "rungs"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "rungs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rung" } }
      }
    },
    "rung": {
      "type": "object",
      "required": ["id", "series", "coils"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "series": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/element" } },
        "coils": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/output" } }
      }
    },
    "output": {
      "oneOf": [
        { "$ref": "#/$defs/coil" },
        { "$ref": "#/$defs/move" },
        { "$ref": "#/$defs/calc" }
      ]
    },
    "move": {
      "type": "object",
      "required": ["type", "dst", "src"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "move" },
        "dst": { "type": "string" },
        "src": { "type": ["number", "string"] }
      }
    },
    "calc": {
      "type": "object",
      "required": ["type", "op", "dst", "a", "b"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "calc" },
        "op": { "enum": ["ADD", "SUB", "MUL", "DIV"] },
        "dst": { "type": "string" },
        "a": { "type": ["number", "string"] },
        "b": { "type": ["number", "string"] }
      }
    },
    "fb": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["R_TRIG", "F_TRIG", "TON", "TOF", "TP", "CTU", "CTD", "SR", "RS"]
        },
        "preset_ms": { "type": "integer", "exclusiveMinimum": 0 },
        "pv": { "type": "integer", "exclusiveMinimum": 0 },
        "reset": { "type": "string" },
        "load": { "type": "string" }
      }
    },
    "element": {
      "oneOf": [
        { "$ref": "#/$defs/contact" },
        { "$ref": "#/$defs/compare" },
        { "$ref": "#/$defs/fbref" },
        { "$ref": "#/$defs/branch" },
        { "$ref": "#/$defs/negation" }
      ]
    },
    "fbref": {
      "type": "object",
      "required": ["type", "instance"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "fb" },
        "instance": { "type": "string" }
      }
    },
    "compare": {
      "type": "object",
      "required": ["type", "op", "left", "right"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "compare" },
        "op": { "enum": ["GT", "GE", "LT", "LE", "EQ", "NE"] },
        "left": { "type": "string" },
        "right": { "type": ["number", "string"] }
      }
    },
    "negation": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "not" }
      }
    },
    "contact": {
      "type": "object",
      "required": ["type", "tag"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "contact" },
        "tag": { "type": "string" },
        "mode": { "enum": ["NO", "NC"] }
      }
    },
    "branch": {
      "type": "object",
      "required": ["branch"],
      "additionalProperties": false,
      "properties": {
        "branch": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/element" }
          }
        }
      }
    },
    "coil": {
      "type": "object",
      "required": ["type", "tag"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "coil" },
        "tag": { "type": "string" },
        "mode": { "enum": ["=", "S", "R"] }
      }
    }
  }
}
